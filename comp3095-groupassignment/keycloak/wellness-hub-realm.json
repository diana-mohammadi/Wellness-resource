{
  "realm": "wellness-hub",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "student",
        "description": "Student role - can create goals and register for events"
      },
      {
        "name": "staff",
        "description": "Staff role - can manage wellness resources"
      },
      {
        "name": "admin",
        "description": "Administrator role - full access"
      }
    ]
  },
  "users": [
    {
      "username": "student1",
      "email": "student1@georgebrown.ca",
      "firstName": "John",
      "lastName": "Student",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["student"]
    },
    {
      "username": "staff1",
      "email": "staff1@georgebrown.ca",
      "firstName": "Jane",
      "lastName": "Staff",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["staff"]
    },
    {
      "username": "admin",
      "email": "admin@georgebrown.ca",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "staff", "student"]
    }
  ],
  "clients": [
    {
      "clientId": "wellness-hub-client",
      "name": "Wellness Hub Client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "wellness-hub-secret",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ]
    },
    {
      "clientId": "wellness-hub-public",
      "name": "Wellness Hub Public Client",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "roles",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
